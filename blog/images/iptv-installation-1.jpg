<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450">
  <rect width="800" height="450" fill="#f0f4ff"/>
  <rect x="0" y="0" width="800" height="70" fill="#002B7F"/>
  <text x="400" y="45" font-family="Arial,sans-serif" font-size="26" font-weight="bold" fill="white" text-anchor="middle">Instalare IPTV — Ghid Complet</text>

  <!-- Internet cloud -->
  <ellipse cx="400" cy="160" rx="80" ry="50" fill="#4A90D9" opacity="0.9"/>
  <text x="400" y="155" font-family="Arial,sans-serif" font-size="14" font-weight="bold" fill="white" text-anchor="middle">INTERNET</text>
  <text x="400" y="173" font-family="Arial,sans-serif" font-size="11" fill="white" text-anchor="middle">Server IPTV</text>

  <!-- Arrows from internet to devices -->
  <line x1="320" y1="180" x2="200" y2="280" stroke="#002B7F" stroke-width="2.5" stroke-dasharray="6,3"/>
  <line x1="400" y1="210" x2="400" y2="280" stroke="#002B7F" stroke-width="2.5" stroke-dasharray="6,3"/>
  <line x1="480" y1="180" x2="600" y2="280" stroke="#002B7F" stroke-width="2.5" stroke-dasharray="6,3"/>
  <line x1="350" y1="190" x2="140" y2="290" stroke="#002B7F" stroke-width="2" stroke-dasharray="5,3"/>

  <!-- Android Box -->
  <rect x="130" y="285" width="100" height="65" rx="8" fill="#FCD116"/>
  <text x="180" y="313" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="#002B7F" text-anchor="middle">Android Box</text>
  <text x="180" y="330" font-family="Arial,sans-serif" font-size="10" fill="#002B7F" text-anchor="middle">/ Phone</text>
  <text x="180" y="345" font-family="Arial,sans-serif" font-size="9" fill="#333" text-anchor="middle">APK Install</text>

  <!-- Smart TV -->
  <rect x="350" y="285" width="100" height="65" rx="8" fill="#CE1126"/>
  <text x="400" y="313" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="white" text-anchor="middle">Smart TV</text>
  <text x="400" y="330" font-family="Arial,sans-serif" font-size="10" fill="white" text-anchor="middle">Samsung/LG</text>
  <text x="400" y="345" font-family="Arial,sans-serif" font-size="9" fill="#ffcccc" text-anchor="middle">Store Install</text>

  <!-- PC -->
  <rect x="560" y="285" width="100" height="65" rx="8" fill="#002B7F"/>
  <text x="610" y="313" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="white" text-anchor="middle">PC / Mac</text>
  <text x="610" y="330" font-family="Arial,sans-serif" font-size="10" fill="#FCD116" text-anchor="middle">Windows</text>
  <text x="610" y="345" font-family="Arial,sans-serif" font-size="9" fill="#cce0ff" text-anchor="middle">VLC / Player</text>

  <!-- Fire Stick -->
  <rect x="240" y="285" width="100" height="65" rx="8" fill="#FF9900"/>
  <text x="290" y="313" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="white" text-anchor="middle">Fire Stick</text>
  <text x="290" y="330" font-family="Arial,sans-serif" font-size="10" fill="white" text-anchor="middle">Amazon</text>
  <text x="290" y="345" font-family="Arial,sans-serif" font-size="9" fill="#fff3e0" text-anchor="middle">Sideload APK</text>

  <!-- Footer -->
  <rect x="0" y="415" width="800" height="35" fill="#002B7F"/>
  <text x="400" y="437" font-family="Arial,sans-serif" font-size="13" fill="#FCD116" text-anchor="middle" font-weight="bold">romaniaiptv.tv — Cel mai bun serviciu IPTV românesc</text>
</svg>
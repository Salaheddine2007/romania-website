<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450">
  <rect width="800" height="450" fill="#ffffff"/>
  <rect x="0" y="0" width="800" height="65" fill="#002B7F"/>
  <text x="400" y="42" font-family="Arial,sans-serif" font-size="24" font-weight="bold" fill="white" text-anchor="middle">Pași pentru Instalarea IPTV</text>

  <!-- Step boxes -->
  <!-- Step 1 -->
  <rect x="30" y="90" width="160" height="130" rx="10" fill="#f0f4ff" stroke="#002B7F" stroke-width="2"/>
  <circle cx="110" cy="110" r="18" fill="#002B7F"/>
  <text x="110" y="116" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="white" text-anchor="middle">1</text>
  <text x="110" y="150" font-family="Arial,sans-serif" font-size="12" font-weight="bold" fill="#002B7F" text-anchor="middle">Alege</text>
  <text x="110" y="167" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">dispozitivul</text>
  <text x="110" y="184" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">TV / Android</text>
  <text x="110" y="201" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">PC / Fire Stick</text>

  <!-- Arrow -->
  <polygon points="198,155 213,148 213,162" fill="#FCD116"/>
  <line x1="190" y1="155" x2="213" y2="155" stroke="#FCD116" stroke-width="3"/>

  <!-- Step 2 -->
  <rect x="215" y="90" width="160" height="130" rx="10" fill="#fff8e1" stroke="#FCD116" stroke-width="2"/>
  <circle cx="295" cy="110" r="18" fill="#FCD116"/>
  <text x="295" y="116" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="#002B7F" text-anchor="middle">2</text>
  <text x="295" y="150" font-family="Arial,sans-serif" font-size="12" font-weight="bold" fill="#002B7F" text-anchor="middle">Descarcă</text>
  <text x="295" y="167" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">aplicația IPTV</text>
  <text x="295" y="184" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">Smarters / TiviMate</text>
  <text x="295" y="201" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">IPTV Extreme</text>

  <!-- Arrow -->
  <polygon points="383,155 398,148 398,162" fill="#FCD116"/>
  <line x1="375" y1="155" x2="398" y2="155" stroke="#FCD116" stroke-width="3"/>

  <!-- Step 3 -->
  <rect x="400" y="90" width="160" height="130" rx="10" fill="#fff0f0" stroke="#CE1126" stroke-width="2"/>
  <circle cx="480" cy="110" r="18" fill="#CE1126"/>
  <text x="480" y="116" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="white" text-anchor="middle">3</text>
  <text x="480" y="150" font-family="Arial,sans-serif" font-size="12" font-weight="bold" fill="#CE1126" text-anchor="middle">Adaugă</text>
  <text x="480" y="167" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">abonamentul</text>
  <text x="480" y="184" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">M3U URL sau</text>
  <text x="480" y="201" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">Xtream Codes</text>

  <!-- Arrow -->
  <polygon points="568,155 583,148 583,162" fill="#FCD116"/>
  <line x1="560" y1="155" x2="583" y2="155" stroke="#FCD116" stroke-width="3"/>

  <!-- Step 4 -->
  <rect x="585" y="90" width="180" height="130" rx="10" fill="#f0f8f0" stroke="#28a745" stroke-width="2"/>
  <circle cx="675" cy="110" r="18" fill="#28a745"/>
  <text x="675" y="116" font-family="Arial,sans-serif" font-size="16" font-weight="bold" fill="white" text-anchor="middle">4</text>
  <text x="675" y="150" font-family="Arial,sans-serif" font-size="12" font-weight="bold" fill="#28a745" text-anchor="middle">Bucură-te!</text>
  <text x="675" y="167" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">Canale românești</text>
  <text x="675" y="184" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">Pro TV, Antena 1</text>
  <text x="675" y="201" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">Digi24, TVR...</text>

  <!-- Info section -->
  <rect x="30" y="250" width="740" height="80" rx="8" fill="#f0f4ff" stroke="#002B7F" stroke-width="1.5"/>
  <text x="400" y="278" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#002B7F" text-anchor="middle">Ce ai nevoie pentru instalare IPTV</text>
  <text x="160" y="302" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">✓ Internet 10+ Mbps</text>
  <text x="320" y="302" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">✓ Abonament IPTV activ</text>
  <text x="490" y="302" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">✓ Dispozitiv compatibil</text>
  <text x="670" y="302" font-family="Arial,sans-serif" font-size="11" fill="#333" text-anchor="middle">✓ Aplicație IPTV</text>
  <text x="400" y="320" font-family="Arial,sans-serif" font-size="10" fill="#555" text-anchor="middle">Instalare simplă în mai puțin de 5 minute!</text>

  <!-- Footer -->
  <rect x="0" y="350" width="800" height="50" fill="#002B7F"/>
  <text x="400" y="381" font-family="Arial,sans-serif" font-size="14" fill="#FCD116" text-anchor="middle" font-weight="bold">romaniaiptv.tv — Instalare IPTV Rapidă și Simplă</text>

  <!-- Romania flag accent -->
  <rect x="30" y="415" width="27" height="20" fill="#002B7F"/>
  <rect x="57" y="415" width="27" height="20" fill="#FCD116"/>
  <rect x="84" y="415" width="27" height="20" fill="#CE1126"/>
</svg>